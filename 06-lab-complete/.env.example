# Copy to .env.local for Docker Compose or load into your platform dashboard.
# Do not commit .env.local.

HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

APP_NAME=Production AI Agent
APP_VERSION=1.0.0

OPENAI_API_KEY=
LLM_MODEL=mock-llm

AGENT_API_KEY=dev-key-change-me
REDIS_URL=redis://localhost:6379/0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0
CONVERSATION_TTL_SECONDS=3600
CONVERSATION_HISTORY_LIMIT=20
MODEL_CONTEXT_MESSAGES=6
PROMETHEUS_ENABLED=true
OTEL_SERVICE_NAME=day12-part6-agent
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_CONSOLE=false
